  "config_yaml": "# P0-M6 G1 stiffness-validity pilot fixture.\n# The 20 primitive sequences below were generated once with numpy.default_rng(42)\n# and are intentionally frozen here; this config is the measurement fixture.\nrope:\n  length_m: 1.0\n  n_segments: 50\n  bend_stiffness: 1.0\n  twist_stiffness: 1.0\n  friction: 1.0\n  radius: 0.005\nsim:\n  dt: 0.001\n  substeps: 5\n  rod_damping: 10.0\n  rod_angular_damping: 5.0\n  initial_settle_steps: 0\n  reset_settle_max_steps: 5000\n  move_step_size: 0.03\n  move_hold_steps: 0\n  # Controlled G1 experiment: grasp realism is off so p/delta/lift are fixed and\n  # stiffness/friction effects are not confounded by grasp failure or node jitter.\n  grasp_realism: false\nmeasurement:\n  fixture_generation_seed: 42\n  init_seeds: [0, 1, 2]\n  stiffness_multipliers: [0.5, 1.0, 2.0]\n  friction_multipliers: [0.5, 1.0, 2.0]\n  condition_pairs:\n    - [0.5, 1.0]\n    - [1.0, 2.0]\n    - [0.5, 2.0]\n  vel_threshold: 0.001\n  settle_max_steps: 5000\n  bootstrap_replicates: 5000\n  bootstrap_ci: 0.95\n  timing_probe:\n    enabled: true\n    axis: stiffness\n    sequence_id: straight_01\n    condition: 1.0\n    primitive_index: 0\nsequences:\n  - id: straight_01\n    init_shape: straight\n    primitives:\n      - {p: 8, delta: [-0.011002, 0.064548, 0.018355], lift: high}\n      - {p: 35, delta: [0.085612, 0.047005, 0.023234], lift: high}\n  - id: straight_02\n    init_shape: straight\n    primitives:\n      - {p: 38, delta: [-0.023256, 0.076818, 0.015413], lift: low}\n      - {p: 23, delta: [-0.010185, -0.049097, 0.010502], lift: high}\n      - {p: 39, delta: [0.0237, 0.046456, -0.000501], lift: low}\n  - id: straight_03\n    init_shape: straight\n    primitives:\n      - {p: 38, delta: [0.070762, 0.050109, -0.009295], lift: low}\n      - {p: 24, delta: [-0.062228, 0.032949, 0.020962], lift: low}\n      - {p: 6, delta: [-0.031351, -0.023317, 0.005826], lift: high}\n      - {p: 23, delta: [-0.004373, -0.049156, 0.01684], lift: hig